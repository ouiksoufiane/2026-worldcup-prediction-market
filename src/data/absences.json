{
  "_meta": {
    "purpose": "Player absences (injuries, suspensions, federation bans) translated into team-level ELO penalties via per-player criticality scoring. See src/lib/sim/absences.ts.",
    "schema": {
      "criticality": "criticality = α·(minutes_qual/720) + β·(market_value_mil/150) + γ·((pos_mult-1.0)/0.5), where α+β+γ=1.0. Position multipliers: GK 1.5, CB 1.3, DM/CM 1.1, ATT 1.0.",
      "penalty": "Per-player ELO penalty = -5 - 75·criticality. Per-team penalty = sum, capped at -150.",
      "normalization_refs": "minutes: max 8 qualifier matches × 90 min = 720. value: global top market value reference (Mbappé/Haaland-tier ≈ 150M €). These are fixed constants so criticality is comparable across eras."
    },
    "fields": {
      "player": "Player full name",
      "position": "GK | CB | FB | DM | CM | AM | WG | ATT",
      "minutes_qual": "Approx total minutes played in qualifying campaign (cap 720)",
      "market_value_mil": "Transfermarkt market value in € millions at tournament start",
      "reason": "Short note on absence cause (injury, suspension, fed ban, etc)",
      "applies_from_stage": "Optional. If omitted, absent from group stage onwards. If set ('r16'|'qf'|'sf'|'final'|'3rd'), absent only from that stage."
    },
    "historical_note": "Historical seed restricted to OUT-FROM-START cases that are publicly documented. Partial absences (injuries mid-tournament) are noted but excluded from calibration to keep the signal clean.",
    "compiled_at": "2026-05-17",
    "current_updated_at": "2026-06-17T12:50:45.400Z",
    "current_source": "transfermarkt squad pages (injury flag)"
  },

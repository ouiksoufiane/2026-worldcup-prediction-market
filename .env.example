# Copy to .env.local and fill in keys.
# .env.local is gitignored — never commit real keys.

# The Odds API — https://the-odds-api.com (free tier: 500 reqs/month)
# Used by `npm run fetch-odds` to pull outright winner odds from major books.
ODDS_API_KEY=

# Polymarket prediction market — public API, no key required.
# Find the market slug at polymarket.com (e.g. "fifa-world-cup-2026-winner").
POLYMARKET_SLUG=
